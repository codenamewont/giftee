{
  "expo": {
    "name": "giftee",
    "slug": "giftee",
    "version": "1.0.0",
    "scheme": "giftee",
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-dev-client",
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6764E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leechaewonkr.giftee"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#F6764E"
      },
      "package": "com.leechaewonkr.giftee"
    }
  }
}
